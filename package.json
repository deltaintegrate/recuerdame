{
  "name": "recuerdame",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:webhook": "npm run dev --workspace=packages/webhook",
    "dev:scheduler": "npm run dev --workspace=packages/scheduler",
    "build": "npm run build --workspaces --if-present",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f"
  }
}
